-- ==================== ГЛУБОКИЙ АНАЛИЗ ====================
local analysisText = ""

local function RunFullAnalysis()
    analysisText = "=== ПОЛНЫЙ АНАЛИЗ VIBEZ UPGRADE TREE ===\n\n"
    
    -- 1. Remotes
    analysisText = analysisText .. "=== REMOTE EVENTS ===\n"
    for _, v in pairs(ReplicatedStorage:GetDescendants()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            analysisText = analysisText .. v.ClassName .. ": " .. v:GetFullName() .. "\n"
        end
    end

    -- 2. Кнопки и структуры
    analysisText = analysisText .. "\n=== КНОПКИ И СТРУКТУРЫ ===\n"
    for _, folder in pairs({Workspace:FindFirstChild("Buttons"), Workspace:FindFirstChild("ExtraButtons"), Workspace:FindFirstChild("RebirthButtons"), Workspace:FindFirstChild("SacrificeButtons")}) do
        if folder then
            analysisText = analysisText .. "Папка: " .. folder:GetFullName() .. "\n"
        end
    end

    -- 3. leaderstats
    analysisText = analysisText .. "\n=== ВАЛЮТЫ ===\n"
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls then
        for _, v in pairs(ls:GetChildren()) do
            analysisText = analysisText .. v.Name .. " = " .. tostring(v.Value) .. "\n"
        end
    end

    print(analysisText)
    
    if setclipboard then
        setclipboard(analysisText)
        Rayfield:Notify({
            Title = "Анализ готов",
            Content = "Скопировано в буфер обмена",
            Duration = 4
        })
    else
        Rayfield:Notify({
            Title = "Готово",
            Content = "Смотри Output (F9)",
            Duration = 4
        })
    end
end

AnalysisTab:CreateButton({
    Name = "Запустить полный анализ + скопировать",
    Callback = RunFullAnalysis
})

AnalysisTab:CreateButton({
    Name = "Показать анализ в консоли",
    Callback = function()
        RunFullAnalysis()
    end
})

